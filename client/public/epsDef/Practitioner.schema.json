{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/epsDef/Practitioner.schema.json",
  "title": "EPS Practitioner",
  "type": "object",
  "additionalProperties": false,
  "required": ["resourceType", "id", "name"],
  "properties": {
    "resourceType": {
      "const": "Practitioner"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs acceptable)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "extension": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "/epsDef/Extension.schema.json" }
    },
    "name": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/HumanName"
      }
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },
  "definitions": {
    "HumanName": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "use": {
          "type": "string",
          "enum": [
            "usual",
            "official",
            "temp",
            "nickname",
            "anonymous",
            "old",
            "maiden"
          ]
        },
        "text": {
          "type": "string"
        },
        "family": {
          "type": "string"
        },
        "given": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prefix": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suffix": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "anyOf": [
        { "required": ["text"] },
        { "required": ["family"] },
        { "required": ["given"] }
      ]
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}