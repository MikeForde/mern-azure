{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/epsDef/Organization.schema.json",
  "title": "EPS Organization",
  "type": "object",
  "additionalProperties": false,
  "required": ["resourceType", "id", "name"],
  "properties": {
    "resourceType": {
      "const": "Organization"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs are fine if you keep them in the id field)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "extension": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "/epsDef/Extension.schema.json" }
    },
    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Identifier" }
    },
    "name": {
      "type": "string",
      "description": "Organization name."
    },
    "address": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Address" }
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },
  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "extension": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "/epsDef/Extension.schema.json" }
        },
        "system": { "type": "string" },
        "value": { "type": "string" },
        "assigner": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "display": { "type": "string" }
          }
        }
      }
    },
    "Address": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "line": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "state": { "type": "string" },
        "postalCode": { "type": "string" },
        "country": { "type": "string" }
      },
      "minProperties": 1
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}