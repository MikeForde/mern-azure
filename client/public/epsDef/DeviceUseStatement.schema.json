{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/epsDef/DeviceUseStatement.schema.json",
  "title": "EPS DeviceUseStatement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceType",
    "id",
    "status",
    "subject",
    "device"
  ],
  "properties": {
    "resourceType": {
      "const": "DeviceUseStatement"
    },

    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$"
    },

    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },

    "text": {
      "$ref": "#/definitions/Narrative"
    },

    "status": {
      "type": "string",
      "enum": [
        "active",
        "completed",
        "entered-in-error",
        "intended",
        "stopped",
        "on-hold"
      ]
    },

    "subject": {
      "$ref": "#/definitions/ReferenceUrnUuidWithDisplay"
    },

    "timingPeriod": {
      "$ref": "#/definitions/Period"
    },

    "device": {
      "$ref": "#/definitions/ReferenceUrnUuidWithDisplay"
    }
  },

  "definitions": {
    "ReferenceUrnUuidWithDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        },
        "display": {
          "type": "string"
        }
      }
    },

    "Period": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "string",
          "anyOf": [
            { "format": "date" },
            { "format": "date-time" }
          ]
        },
        "end": {
          "type": "string",
          "anyOf": [
            { "format": "date" },
            { "format": "date-time" }
          ]
        }
      },
      "minProperties": 1
    },

    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}