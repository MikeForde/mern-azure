{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/epsDef/PractitionerRole.schema.json",
  "title": "EPS PractitionerRole",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceType",
    "id",
    "practitioner",
    "organization"
  ],
  "properties": {
    "resourceType": {
      "const": "PractitionerRole"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs acceptable)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "extension": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "/epsDef/Extension.schema.json"
      }
    },
    "practitioner": {
      "$ref": "#/definitions/ReferenceUrnUuidWithOptionalDisplay"
    },
    "organization": {
      "$ref": "#/definitions/ReferenceUrnUuidWithOptionalDisplay"
    },
    "code": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/CodeableConceptNoDisplay"
      }
    },
    "specialty": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/CodeableConceptNoDisplay"
      }
    },
    "telecom": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/ContactPoint"
      }
    },
    "text": {
      "$ref": "#/definitions/Narrative"
    }
  },
  "definitions": {
    "ReferenceUrnUuidWithOptionalDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        },
        "display": {
          "type": "string"
        }
      }
    },
    "CodeableConceptNoDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/CodingNoDisplay"
          }
        },
        "text": {
          "type": "string"
        }
      }
    },
    "CodingNoDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code"],
      "properties": {
        "system": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "display": {
          "type": "string"
        }
      }
    },
    "ContactPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": {
          "type": "string",
          "enum": ["phone", "fax", "email", "pager", "url", "sms", "other"]
        },
        "value": {
          "type": "string"
        },
        "use": {
          "type": "string",
          "enum": ["home", "work", "temp", "old", "mobile"]
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}