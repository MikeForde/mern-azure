{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/epsDef/Immunization.schema.json",
  "title": "EPS Immunization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceType",
    "id",
    "status",
    "vaccineCode",
    "patient",
    "occurrenceDateTime"
  ],
  "properties": {
    "resourceType": {
      "const": "Immunization"
    },

    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$"
    },

    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },

    "text": {
      "$ref": "#/definitions/Narrative"
    },

    "status": {
      "type": "string",
      "enum": [
        "completed",
        "entered-in-error",
        "not-done"
      ]
    },

    "vaccineCode": {
      "$ref": "#/definitions/CodeableConcept"
    },

    "patient": {
      "$ref": "#/definitions/ReferenceUrnUuidWithDisplay"
    },

    "occurrenceDateTime": {
      "type": "string",
      "anyOf": [
        { "format": "date" },
        { "format": "date-time" }
      ]
    },

    "recorded": {
      "type": "string",
      "anyOf": [
        { "format": "date" },
        { "format": "date-time" }
      ]
    },

    "lotNumber": {
      "type": "string"
    },

    "expirationDate": {
      "type": "string",
      "format": "date"
    },

    "site": {
      "$ref": "#/definitions/CodeableConcept"
    },

    "route": {
      "$ref": "#/definitions/CodeableConcept"
    }
  },

  "definitions": {
    "ReferenceUrnUuidWithDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        },
        "display": {
          "type": "string"
        }
      }
    },

    "CodeableConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Coding"
          }
        },
        "text": {
          "type": "string"
        }
      }
    },

    "Coding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code"],
      "properties": {
        "system": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "display": {
          "type": "string"
        }
      }
    },

    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}