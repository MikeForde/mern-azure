{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/epsDef/AllergyIntolerance.schema.json",
  "title": "EPS AllergyIntolerance",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "resourceType",
    "id",
    "clinicalStatus",
    "verificationStatus",
    "code",
    "patient",
    "onsetDateTime"
  ],
  "properties": {
    "resourceType": {
      "const": "AllergyIntolerance"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred; UUIDs are fine."
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "profile": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    },
    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Identifier"
      }
    },
    "extension": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "/epsDef/Extension.schema.json"
      }
    },
    "clinicalStatus": {
      "$ref": "#/definitions/CodeableConceptNoDisplay"
    },
    "verificationStatus": {
      "$ref": "#/definitions/CodeableConceptNoDisplay"
    },
    "type": {
      "type": "string",
      "enum": [
        "allergy",
        "intolerance"
      ]
    },
    "category": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "food",
          "medication",
          "environment",
          "biologic"
        ]
      }
    },
    "code": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "patient": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "description": "EPS example uses a URN UUID reference.",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        },
        "display": {
          "type": "string"
        }
      }
    },
    "onsetDateTime": {
      "type": "string",
      "description": "EPS example uses a date only, but some sources may use full date-time.",
      "anyOf": [
        { "format": "date" },
        { "format": "date-time" }
      ]
    },
    "recordedDate": {
      "type": "string",
      "anyOf": [
        { "format": "date" },
        { "format": "date-time" }
      ]
    },
    "text": {
      "$ref": "#/definitions/Narrative"
    }
  },
  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "CodeableConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Coding" }
        },
        "text": { "type": "string" }
      }
    },
    "CodeableConceptNoDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/CodingNoDisplay" }
        },
        "text": { "type": "string" }
      }
    },
    "Coding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "CodingNoDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code"],
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}