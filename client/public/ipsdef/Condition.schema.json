{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsdef/Condition.schema.json",
  "title": "NPS Condition",
  "type": "object",
  "required": [
    "resourceType",
    "id",
    "code",
    "subject"
  ],
  "anyOf": [
    { "required": ["onsetDateTime"] },
    { "required": ["recordedDate"] }
  ],
  "description": "At least one date must be supplied. onsetDateTime is preferred where known; recordedDate may be used as a fallback when onsetDateTime is unavailable.",
  "properties": {
    "resourceType": {
      "const": "Condition"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "simple ids preferred",
      "examples": ["condition1, condition2...conditionN"]
    },
    "code": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "subject": {
      "type": "object",
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^Patient\\/[A-Za-z0-9\\-\\.]+$"
        }
      }
    },
    "onsetDateTime": {
      "type": "string",
      "anyOf": [
        {
          "format": "date"
        },
        {
          "format": "date-time"
        }
      ]
    },
    "recordedDate": {
      "type": "string",
      "anyOf": [
        {
          "format": "date"
        },
        {
          "format": "date-time"
        }
      ],
      "description": "Date the condition was recorded."
    }
  },
  "definitions": {
    "CodeableConcept": {
      "type": "object",
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/Coding"
          }
        },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Coding": {
      "type": "object",
      "required": ["system", "code", "display"],
      "properties": {
        "system": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "display": {
          "type": "string"
        }
      }
    }
  }
}