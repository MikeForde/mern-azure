{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/Observation.schema.json",
  "title": "NHS SCR IPS Observation",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "resourceType",
    "id",
    "status",
    "code",
    "subject",
    "effectiveDateTime"
  ],
  "properties": {
    "resourceType": { "const": "Observation" },

    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$"
    },

    "extension": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "/ipsNhsScrDef/Extension.schema.json" },
      "description": "UK Core / NHS SCR extensions."
    },

    "status": {
      "type": "string",
      "enum": [
        "registered",
        "preliminary",
        "final",
        "amended",
        "corrected",
        "cancelled",
        "unknown"
      ]
    },

    "code": { "$ref": "#/definitions/CodeableConcept" },

    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "description": "NHS SCR examples use URN UUID references for the Patient.",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        }
      }
    },

    "effectiveDateTime": { "type": "string", "format": "date-time" },

    "valueQuantity": { "$ref": "#/definitions/Quantity" },

    "component": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ObservationComponent" }
    },

    "bodySite": { "$ref": "#/definitions/CodeableConcept" },
    "text": { "$ref": "#/definitions/Narrative" }
  },

  "definitions": {
    "CodeableConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Coding" }
        },
        "text": { "type": ["string", "null"] }
      }
    },

    "Coding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "display": { "type": "string" }
      }
    },

    "Quantity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit", "system", "code"],
      "properties": {
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "system": { "type": "string" },
        "code": { "type": "string" }
      }
    },

    "ObservationComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "valueQuantity"],
      "properties": {
        "code": { "$ref": "#/definitions/CodeableConcept" },
        "valueQuantity": { "$ref": "#/definitions/Quantity" }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}