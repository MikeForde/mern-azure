{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/AllergyIntolerance.schema.json",
  "title": "NHS SCR IPS AllergyIntolerance",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "resourceType",
    "id",
    "identifier",
    "clinicalStatus",
    "verificationStatus",
    "code",
    "patient",
    "onsetDateTime"
  ],
  "properties": {
    "resourceType": {
      "const": "AllergyIntolerance"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs are fine if you keep them in the id field)."
    },
    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/Identifier"
      }
    },
    "extension": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "/ipsNhsScrDef/Extension.schema.json"
      },
      "description": "Primarily included for optional religion field, but can be used for other extensions as well"
    },
    "clinicalStatus": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "verificationStatus": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "code": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "patient": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "description": "In the SCR IPS example this is a URN UUID reference.",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        }
      }
    },
    "onsetDateTime": {
      "type": "string",
      "format": "date-time",
      "description": "SCR IPS example uses date-time."
    },
    "recordedDate": {
      "type": "string",
      "format": "date-time",
      "description": "SCR IPS example uses date-time."
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },
  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "CodeableConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Coding" }
        },
        "text": { "type": "string" }
      }
    },
    "Coding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "display": { "type": "string" }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}