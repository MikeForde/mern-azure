{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/DiagnosticReport.schema.json",
  "title": "NHS SCR IPS DiagnosticReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceType",
    "id",
    "contained",
    "identifier",
    "status",
    "category",
    "code",
    "subject",
    "effectiveDateTime",
    "resultsInterpreter",
    "specimen",
    "result"
  ],
  "properties": {
    "resourceType": { "const": "DiagnosticReport" },

    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$"
    },

    "contained": {
      "type": "array",
      "minItems": 2,
      "items": {
        "anyOf": [
          { "$ref": "#/definitions/ContainedSpecimen" },
          { "$ref": "#/definitions/ContainedResultsInterpreterPractitioner" }
        ]
      }
    },

    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Identifier" }
    },

    "extension": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "/ipsNhsScrDef/Extension.schema.json"
      },
      "description": "Primarily included for optional religion field, but can be used for other extensions as well"
    },

    "status": {
      "type": "string",
      "enum": [
        "registered",
        "partial",
        "preliminary",
        "final",
        "amended",
        "corrected",
        "appended",
        "cancelled",
        "entered-in-error",
        "unknown"
      ]
    },

    "category": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/CodeableConcept" }
    },

    "code": { "$ref": "#/definitions/CodeableConcept" },

    "subject": { "$ref": "#/definitions/ReferenceUrnUuid" },

    "performer": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ReferenceUrnUuid" }
    },

    "effectiveDateTime": { "type": "string", "format": "date-time" },

    "resultsInterpreter": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ReferenceContainedResultsInterpreter" }
    },

    "specimen": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ReferenceContainedSpecimen" }
    },

    "result": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/ReferenceUrnUuid" }
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },

  "allOf": [
    {
      "description": "Must include Specimen(id='specimen') and Practitioner(id='resultsInterpreter') in contained[].",
      "properties": {
        "contained": {
          "allOf": [
            { "contains": { "$ref": "#/definitions/ContainedSpecimen" } },
            { "contains": { "$ref": "#/definitions/ContainedResultsInterpreterPractitioner" } }
          ]
        }
      }
    }
  ],

  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": { "type": "string" },
        "value": { "type": "string" }
      }
    },

    "Coding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "display": { "type": "string" }
      }
    },

    "CodeableConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Coding" }
        },
        "text": { "type": "string" }
      }
    },

    "ReferenceUrnUuid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        }
      }
    },

    "ReferenceContainedSpecimen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": { "const": "#specimen" }
      }
    },

    "ReferenceContainedResultsInterpreter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": { "const": "#resultsInterpreter" }
      }
    },

    "ContainedResultsInterpreterPractitioner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceType", "id", "name"],
      "properties": {
        "resourceType": { "const": "Practitioner" },
        "id": { "const": "resultsInterpreter" },
        "name": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/HumanNameTextOnly" }
        }
      }
    },

    "HumanNameTextOnly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": { "type": "string" }
      }
    },

    "ContainedSpecimen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resourceType", "id", "identifier", "type", "receivedTime", "collection"],
      "properties": {
        "resourceType": { "const": "Specimen" },
        "id": { "const": "specimen" },

        "identifier": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Identifier" }
        },

        "type": { "$ref": "#/definitions/CodeableConcept" },

        "receivedTime": { "type": "string", "format": "date-time" },

        "collection": { "$ref": "#/definitions/SpecimenCollection" }
      }
    },

    "SpecimenCollection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collectedDateTime"],
      "properties": {
        "collectedDateTime": { "type": "string", "format": "date-time" }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}