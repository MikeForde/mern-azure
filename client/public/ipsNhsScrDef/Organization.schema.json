{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/Organization.schema.json",
  "title": "NHS SCR IPS Organization",
  "type": "object",
  "additionalProperties": false,
  "required": ["resourceType", "id", "name"],
  "properties": {
    "resourceType": {
      "const": "Organization"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs are fine if you keep them in the id field)."
    },
    "extension": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "/ipsNhsScrDef/Extension.schema.json" },
      "description": "UK Core / NHS SCR extensions."
    },
    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Identifier" }
    },
    "name": {
      "type": "string",
      "description": "Organization name (e.g., NHS org name, manufacturer name, or 'Unknown' in contained source org)."
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },
  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "extension": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "/ipsNhsScrDef/Extension.schema.json" }
        },
        "system": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}