{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/Device.schema.json",
  "title": "NHS SCR IPS Device",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceType",
    "id",
    "identifier",
    "manufacturer",
    "deviceName"
  ],
  "properties": {
    "resourceType": { "const": "Device" },

    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$"
    },

    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Identifier" }
    },
    
    "extension": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "/ipsNhsScrDef/Extension.schema.json"
      },
      "description": "Primarily included for optional religion field, but can be used for other extensions as well"
    },

    "manufacturer": {
      "type": "string"
    },

    "deviceName": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/DeviceName" }
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },

  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": { "type": "string" },
        "value": { "type": "string" }
      }
    },

    "DeviceName": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "udi-label-name",
            "user-friendly-name",
            "patient-reported-name",
            "manufacturer-name",
            "model-name",
            "other"
          ]
        }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}