{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/Condition.schema.json",
  "title": "NHS SCR IPS Condition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resourceType",
    "id",
    "identifier",
    "clinicalStatus",
    "category",
    "code",
    "subject",
    "onsetDateTime"
  ],
  "properties": {
    "resourceType": {
      "const": "Condition"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs are fine if you keep them in the id field)."
    },
    "identifier": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/Identifier" }
    },
    "clinicalStatus": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "category": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/CodeableConcept" }
    },
    "code": {
      "$ref": "#/definitions/CodeableConcept"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference"],
      "properties": {
        "reference": {
          "type": "string",
          "description": "In the SCR IPS example this is a URN UUID reference.",
          "pattern": "^urn:uuid:[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        }
      }
    },
    "onsetDateTime": {
      "type": "string",
      "format": "date-time"
    }
  },
  "definitions": {
    "Identifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "value"],
      "properties": {
        "system": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "CodeableConcept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coding"],
      "properties": {
        "coding": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Coding" }
        },
        "text": { "type": "string" }
      }
    },
    "Coding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": { "type": "string" },
        "code": { "type": "string" },
        "display": { "type": "string" }
      }
    }
  }
}