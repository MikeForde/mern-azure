{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/ipsNhsScrDef/Practitioner.schema.json",
  "title": "NHS SCR IPS Practitioner",
  "type": "object",
  "additionalProperties": false,
  "required": ["resourceType", "id", "name"],
  "properties": {
    "resourceType": {
      "const": "Practitioner"
    },
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9\\-\\.]{1,64}$",
      "description": "Simple ids preferred (UUIDs acceptable)."
    },
    "extension": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "/ipsNhsScrDef/Extension.schema.json" },
      "description": "UK Core / NHS SCR extensions."
    },
    "name": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/HumanName"
      }
    },
    "text": { "$ref": "#/definitions/Narrative" }
  },
  "definitions": {
    "HumanName": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "description": "Display name of practitioner (e.g., 'Unknown' in minimal SCR example)."
        },
        "family": {
          "type": "string"
        },
        "given": {
          "type": "array",
          "items": { "type": "string" }
        },
        "prefix": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suffix": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "Narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "div"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["generated", "extensions", "additional", "empty"]
        },
        "div": {
          "type": "string",
          "description": "XHTML string (kept as string here; full XHTML validation is out of scope)."
        }
      }
    }
  }
}